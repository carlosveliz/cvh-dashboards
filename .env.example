# ---- App secrets / config ----
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=14
CONTENT_TOKEN_TTL_SEC=300
MAX_UPLOAD_MB=50

# ---- First-run admin (seeded if no admin exists) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Administrator

# ---- Database ----
POSTGRES_USER=cvh
POSTGRES_PASSWORD=cvh_password
POSTGRES_DB=cvh_dashboards
# DATABASE_URL is built from the above inside docker-compose; override only if needed.
# DATABASE_URL=postgresql+asyncpg://cvh:cvh_password@db:5432/cvh_dashboards

# ---- Uploads ----
UPLOAD_DIR=/data/uploads

# ---- SMTP (optional). If unset, invitations return a copyable link. ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_TLS=true

# Public base URL of the app (used to build invitation links)
APP_BASE_URL=http://localhost:8080
